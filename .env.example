# 환경변수 템플릿. 실제 값은 .env.local 에 채운다(커밋 금지).
# 규칙: NEXT_PUBLIC_ 접두사는 브라우저에 노출됨 → 시크릿엔 절대 사용 금지.

# ===== Supabase =====
# 클라이언트 노출 OK
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — RLS 우회 서비스 롤 키. 절대 클라이언트/NEXT_PUBLIC_ 금지.
SUPABASE_SERVICE_ROLE_KEY=

# ===== Toss Payments =====
# 결제창 호출용 클라이언트 키 (브라우저 노출 전제)
NEXT_PUBLIC_TOSS_CLIENT_KEY=
# 서버 결제 승인/취소 API 인증용 시크릿 키. 절대 클라이언트/NEXT_PUBLIC_ 금지.
TOSS_SECRET_KEY=

# ===== 결제 모드 =====
# fake(개발): 두 값 모두 '1' → 실제 토스 위젯 대신 reserve→confirm 직호출.
# real(실연동): 두 값 모두 '0' + 위의 NEXT_PUBLIC_TOSS_CLIENT_KEY/TOSS_SECRET_KEY 에
#   토스 대시보드 테스트 키(test_ck_.../test_sk_...) 입력 → 결제위젯 렌더 + 서버 재검증.
NEXT_PUBLIC_PAYMENTS_FAKE=1
TOSS_FAKE=1

# ===== 문자 알림 (솔라피) =====
# 세 값이 모두 채워지면 실제 SMS 발송, 하나라도 비면 noop(발송 없이 이력만 기록).
# 알림톡은 템플릿 승인이 필요하므로 우선 일반 SMS로 시작한다.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
# 사전등록된 발신번호(한국 법상 필수). 숫자만/하이픈 무관. 예: 033-641-1234
SOLAPI_SENDER=
# 관리자 알림 수신 번호(선택). 비우면 관리자 문자는 보내지 않음.
ADMIN_NOTIFY_PHONE=
# 발송 일시 정지(점검·테스트용). '1'이면 SOLAPI 키가 있어도 실제 발송 안 함(noop).
# 발송 이력(notifications)은 그대로 기록된다. 평상시엔 비우거나 '0'.
NOTIFICATIONS_DISABLED=0
